{
  "version": 2,
  "name": "campusgenie",
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "backend/app/main.py",
      "dest": "/api"
    }
  ],
  "env": {
    "OLLAMA_MODEL": "gemma:2b",
    "OLLAMA_BASE_URL": "https://api.openai.com/v1",
    "CHROMA_HOST": "campusgenie-chroma.vercel.app",
    "CHROMA_PORT": "8000",
    "CHROMA_COLLECTION": "campus_docs",
    "BACKEND_HOST": "0.0.0.0",
    "BACKEND_PORT": "8080",
    "MAX_UPLOAD_SIZE_MB": "50",
    "CHUNK_SIZE": "500",
    "CHUNK_OVERLAP": "50",
    "RETRIEVAL_TOP_K": "5",
    "UPLOAD_DIR": "/tmp/uploads",
    "LOG_LEVEL": "INFO",
    "CORS_ORIGINS": "*"
  }
}
